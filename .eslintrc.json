{
    "env": {
        "browser": true,
        "es2021": true
    },
    "extends": [
        "eslint:recommended",
        "plugin:react/recommended",
        "next",
        "next/core-web-vitals"
    ],
    "rules": {
      "require-await": "error",
      "react/jsx-no-bind": [
        "error",
        {
          "ignoreRefs": true,
          "allowArrowFunctions": true,
          "allowFunctions": false,
          "allowBind": false
        }
      ],
      "no-script-url": "error"
    }
}